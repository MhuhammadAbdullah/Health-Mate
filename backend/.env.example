# ═══════════════════════════════════════════════════════════════════
# HealthMate v3 — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

PORT=5000
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/healthmate

# ── CLERK AUTH (dono keys chahiye) ─────────────────────────────────
# dashboard.clerk.com → Your App → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_USER_IDS=user_xxxxxxxxxxxxxxxxxxxx


# ── AI PROVIDER ────────────────────────────────────────────────────
# Choose one: gemini (FREE) | groq (FREE) | anthropic (paid) | openai (paid)
AI_PROVIDER=gemini

# ── GEMINI API KEY (FREE - RECOMMENDED) ────────────────────────────
# Get free key (no card needed): https://aistudio.google.com/app/apikey
# Free limits: 15 req/min, 1500 req/day — plenty for personal use
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GROQ API KEY (FREE alternative) ────────────────────────────────
# Get free key (no card needed): https://console.groq.com
# Uses Llama 3.1 70B — very fast, no image analysis
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ANTHROPIC API KEY (Paid) ────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── OPENAI API KEY (Paid) ───────────────────────────────────────────
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ── CLOUDINARY (File Storage) ───────────────────────────────────────
# Get free account: https://cloudinary.com (25GB free)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── APP ─────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
